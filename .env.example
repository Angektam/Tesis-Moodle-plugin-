# OpenAI API Configuration
# Obtén tu key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Servidor
PORT=3000
NODE_ENV=development

# MySQL / Moodle DB
DB_HOST=localhost
DB_NAME=moodle
DB_USER=root
DB_PASS=your-db-password-here
DB_PREFIX=mdl_

# Judge0 (opcional, para ejecución de código)
# Obtén tu key en: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=your-judge0-key-here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
